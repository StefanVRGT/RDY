{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "formatter": {
    "enabled": false
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "security": {
        "noDangerouslySetInnerHtml": "error",
        "noGlobalEval": "error"
      },
      "suspicious": {
        "noDuplicateObjectKeys": "error",
        "noFallthroughSwitchClause": "error",
        "noRedeclare": "error",
        "noSelfCompare": "error",
        "noDebugger": "error"
      },
      "correctness": {
        "noConstAssign": "error",
        "noUnreachable": "error"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn"
      }
    }
  },
  "files": {
    "includes": ["src/**"]
  }
}
